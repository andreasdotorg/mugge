# pcm-bridge monitor instance — taps CamillaDSP loopback sink monitor ports.
# Passive monitoring: does not participate in the RT audio graph, cannot cause xruns.
# Deployed to /etc/pcm-bridge/monitor.env on the Pi.

MODE=monitor
TARGET=loopback-8ch-sink
PORT=9090
CHANNELS=3
RATE=48000
QUANTUM=256
EXTRA_ARGS=
